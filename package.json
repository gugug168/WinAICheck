{
  "name": "aicoevo",
  "version": "0.1.0",
  "description": "Windows AI 开发环境一键诊断与修复工具 - 扫描 25 个维度，自动修复常见问题",
  "type": "module",
  "bin": {
    "aicoevo": "src/main.ts"
  },
  "keywords": [
    "ai",
    "diagnostic",
    "windows",
    "environment",
    "gpu",
    "cuda",
    "python",
    "node",
    "fix",
    "scanner"
  ],
  "license": "MIT",
  "scripts": {
    "dev": "bun run src/main.ts",
    "dev:cli": "bun run src/main.ts -- --cli",
    "build": "bun run scripts/prebuild.ts && bun build --compile --minify src/main.ts --outfile dist/aicoevo.exe",
    "test": "bun test"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "typescript": "^5.5.0"
  }
}
