{
  "name": "winaicheck",
  "version": "0.3.13",
  "description": "Windows AI 开发环境一键诊断与修复工具 - 扫描 37 个维度，反馈收集，社区悬赏，经验值系统",
  "type": "module",
  "bin": {
    "winaicheck": "bin/winaicheck.js",
    "winaicheck-agent": "bin/agent-lite.js"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "files": [
    "bin/",
    "src/"
  ],
  "keywords": [
    "ai",
    "diagnostic",
    "windows",
    "environment",
    "gpu",
    "cuda",
    "python",
    "node",
    "fix",
    "scanner",
    "winaicheck",
    "aicheck"
  ],
  "author": "大古",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gugug168/WinAICheck.git"
  },
  "homepage": "https://github.com/gugug168/WinAICheck#readme",
  "bugs": {
    "url": "https://github.com/gugug168/WinAICheck/issues"
  },
  "scripts": {
    "dev": "bun run src/main.ts",
    "dev:cli": "bun run src/main.ts -- --cli",
    "build": "bun run scripts/build.ts",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun run scripts/test-all.ts",
    "test:core": "bun run scripts/test-all.ts core",
    "test:integration": "bun run scripts/test-all.ts integration",
    "test:all": "bun run scripts/test-all.ts all",
    "test:aggregate": "bun test"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "typescript": "^5.5.0"
  }
}
